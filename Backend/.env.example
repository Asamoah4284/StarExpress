# Copy to `.env` and fill in values.
#
# Important: variables starting with VITE_ belong in Frontend/.env — Vite never reads Backend/.env
# for the browser bundle.

PORT=4000

# MongoDB connection string (required). Alias: MONGO_URI
# Example Atlas: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# If the password contains @ : / # ? [ ] characters, URL-encode them in the URI.
#
# If you see: querySrv ECONNREFUSED _mongodb._tcp.<cluster>...
#   mongodb+srv needs working DNS (SRV lookup). Fix: use public DNS (e.g. 1.1.1.1 / 8.8.8.8) on Windows,
#   try off VPN, or in Atlas → Connect → "Drivers" use the standard (non-SRV) connection string:
#   mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/?tls=true&replicaSet=...&authSource=admin
# Optional: force DNS resolvers for this Node process only (helps some corporate / broken resolver setups):
# MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8
MONGODB_URI=

# Windows / some networks: Atlas TLS can fail with ERR_SSL_TLSV1_ALERT_INTERNAL_ERROR when
# IPv6 is broken. Prefer one of:
#   MONGODB_FAMILY=4          (or ipv4; use auto for driver default)
#   MONGODB_FORCE_IPV4=true
#   MONGODB_CONNECT_FAMILY=4

# Optional: fail faster during server selection (milliseconds)
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000

# Database name (optional, default: starexpress)
# MONGODB_DB_NAME=starexpress

# Demo catalog (locations, packages, sales, …): not run on API startup unless enabled.
# First-time setup: CATALOG_SEED_ON_STARTUP=true once, or from Backend/: npm run seed:catalog
# CATALOG_SEED_ON_STARTUP=true

# Secret for signing JWTs — min 16 characters in production
JWT_SECRET=

# Optional token lifetime (jsonwebtoken format), default 7d
# JWT_EXPIRES_IN=7d

# Allowed browser origin(s) for CORS (comma-separated). Defaults include localhost + 127.0.0.1 (Vite).
# Any https://*.vercel.app is also allowed unless you set CORS_DISABLE_VERCEL_APP=true (previews + prod).
# Example extra origins: CORS_ORIGIN=http://localhost:5173,https://app.example.com
CORS_ORIGIN=http://localhost:5173

# Set to true to block automatic CORS for all *.vercel.app hosts (only CORS_ORIGIN list will apply).
# CORS_DISABLE_VERCEL_APP=true

# Built-in admin (password hashed on startup / upserted into MongoDB)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# bcrypt cost (optional)
# BCRYPT_SALT_ROUNDS=10

# --- Moolre SMS (signup OTP) — https://api.moolre.com/open/sms/send ---
# JWT from Moolre (sent as header X-API-VASKEY). Never expose in the frontend.
# MOOLRE_API_KEY=
# Alias supported: MOOLRE_SMS_API_KEY=
# Sender name / ID shown on SMS (optional)
# MOOLRE_SENDER_ID=StarExpress
# Optional: override if Moolre changes the path
# MOOLRE_SMS_URL=https://api.moolre.com/open/sms/send
# Optional: default test number for scripts/test-moolre-sms.js
# TEST_SMS_PHONE=0542343069

# --- Moolre MoMo (USSD voucher sales) — https://docs.moolre.com ---
# Same credentials as As-market / Moolre dashboard (Direct Debit + payment webhook).
# MOOLRE_USERNAME=
# MOOLRE_PUBLIC_KEY=
# MOOLRE_ACCOUNT_NUMBER=
# Webhook secret Moolre sends (body secret or x-moolre-secret header)
# MOOLRE_WEBHOOK_SECRET=
# Only if Moolre does not send a secret on callbacks (not recommended in production):
# MOOLRE_WEBHOOK_ALLOW_MISSING_SECRET=true
# Public API URL (Render) — must be HTTPS in production
# BACKEND_URL=https://starexpress.onrender.com
# Wallet callback (same as Moolre dashboard → API → Callback URL)
# MOOLRE_PAYMENT_CALLBACK_URL=https://starexpress.onrender.com/api/moolre/callback
# Allow webhooks when Moolre does not send a secret field
# MOOLRE_WEBHOOK_ALLOW_MISSING_SECRET=true
# Payment channels (Moolre docs): MTN=13, Telecel=6, AT=7
# MOOLRE_CHANNEL_MTN=13
# MOOLRE_CHANNEL_TELECEL=6
# MOOLRE_CHANNEL_AT=7
# MOOLRE_CHANNEL_VODAFONE=15
# Delay after USSD ends before MoMo API (ms). Default 1500 — reduces missed PIN prompts.
# USSD_MOMO_START_DELAY_MS=1500
# Backup if wallet webhook is slow (ms intervals, comma-separated)
# USSD_PAYMENT_POLL_DELAYS_MS=15000,45000,90000
# Keep USSD payment sessions in MongoDB (ms). Default 45 minutes.
# USSD_SESSION_TTL_MS=2700000

# --- USSD (*203*419# via Moolre) ---
# Optional: restrict USSD to one wifi location (locations collection _id).
# If unset, callers choose from all locations that have voucher stock.
# USSD_DEFAULT_LOCATION_ID=loc-xxxxxxxx
# Shortcode shown in menus (informational)
# USSD_SHORTCODE=*203*419#
# Moolre USSD dial flow: POST {BACKEND_URL}/ussd
# Wallet API callback (Wallet Settings → API): POST {BACKEND_URL}/api/moolre/callback
# Same handler also at: POST {BACKEND_URL}/ussd/payments/webhook

# HTTP health: GET /health | GET /api/health (Mongo ping) | GET /api/health/live | GET /api/health/ready
