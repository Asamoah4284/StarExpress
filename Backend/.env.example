# Copy to `.env` and fill in values.
#
# Important: variables starting with VITE_ belong in Frontend/.env — Vite never reads Backend/.env
# for the browser bundle.

PORT=4000

# MongoDB connection string (required). Alias: MONGO_URI
# Example Atlas: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# If the password contains @ : / # ? [ ] characters, URL-encode them in the URI.
#
# If you see: querySrv ECONNREFUSED _mongodb._tcp.<cluster>...
#   mongodb+srv needs working DNS (SRV lookup). Fix: use public DNS (e.g. 1.1.1.1 / 8.8.8.8) on Windows,
#   try off VPN, or in Atlas → Connect → "Drivers" use the standard (non-SRV) connection string:
#   mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/?tls=true&replicaSet=...&authSource=admin
# Optional: force DNS resolvers for this Node process only (helps some corporate / broken resolver setups):
# MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8
MONGODB_URI=

# Windows / some networks: Atlas TLS can fail with ERR_SSL_TLSV1_ALERT_INTERNAL_ERROR when
# IPv6 is broken. Prefer one of:
#   MONGODB_FAMILY=4          (or ipv4; use auto for driver default)
#   MONGODB_FORCE_IPV4=true
#   MONGODB_CONNECT_FAMILY=4

# Optional: fail faster during server selection (milliseconds)
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000

# Database name (optional, default: starexpress)
# MONGODB_DB_NAME=starexpress

# Demo catalog (locations, packages, sales, …): not run on API startup unless enabled.
# First-time setup: CATALOG_SEED_ON_STARTUP=true once, or from Backend/: npm run seed:catalog
# CATALOG_SEED_ON_STARTUP=true

# Secret for signing JWTs — min 16 characters in production
JWT_SECRET=

# Optional token lifetime (jsonwebtoken format), default 7d
# JWT_EXPIRES_IN=7d

# Allowed browser origin for CORS
CORS_ORIGIN=http://localhost:5173

# Built-in admin (password hashed on startup / upserted into MongoDB)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# bcrypt cost (optional)
# BCRYPT_SALT_ROUNDS=10

# HTTP health: GET /health | GET /api/health (Mongo ping) | GET /api/health/live | GET /api/health/ready
