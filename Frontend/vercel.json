{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://starexpress.quickxlearn.com/api/:path*"
    },
    {
      "source": "/ussd/:path*",
      "destination": "https://starexpress.quickxlearn.com/ussd/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
