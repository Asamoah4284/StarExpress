# Copy to `.env` in this folder. Restart Vite after edits (`npm run dev` in Frontend).

# --- API mode (required for real login/signup against Backend) ---
# These are NOT read from Backend/.env — only from this file.
VITE_USE_BACKEND=false

# Leave empty in dev (Vite proxies /api → Backend). Set full URL only if you call the API from another origin.
VITE_API_BASE_URL=

# Vite dev only: proxy target (see vite.config.js)
BACKEND_URL=http://127.0.0.1:4000

# Optional: extra API logging in the browser console outside dev
# VITE_DEBUG_API=true

# --- end API mode ---
