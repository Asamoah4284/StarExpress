# Copy to `.env` in this folder. Restart Vite after edits (`npm run dev` in Frontend).

# Leave empty in dev (Vite proxies /api → Backend).
# Production: set in `.env.production` or your host's build env (see `.env.production` in this folder).
VITE_API_BASE_URL=

# Vite dev only: proxy target (see vite.config.js)
BACKEND_URL=http://127.0.0.1:4000

# Optional: extra API logging in the browser console outside dev
# VITE_DEBUG_API=true

# Sales agent commission rate on completed sales (0–1). Default 0.2 = 20%
# VITE_SALES_AGENT_COMMISSION_RATE=0.2
